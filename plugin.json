{
    "name": "freshcart-validation-plugin",
    "displayName": "FreshCart Validation Plugin",
    "version": "1.0.0",
    "description": "Deployable MCP validation plugin for Cursor",
    "author": "Kirthana",
    "mcpServers": {
      "freshcart-hooks": {
        "command": "python3",
        "args": ["server.py"],
         "env": {
        "FRESHCART_RECEIVER_URL": "http://localhost:8001/hooks/validations",
         "FRESHCART_PROJECT_ROOT": "/home/kirthanas/freshcart-ai"
         }
      }
    }
}  